CREATE TABLE region_manager (
    region VARCHAR(50),
    manager_name VARCHAR(50)
);
SELECT e.region, r.manager_name, SUM(e.sales)
FROM ecom_sales e
JOIN region_manager r
ON e.region = r.region
GROUP BY e.region, r.manager_name;

SELECT 
    YEAR(order_date) AS year,
    MONTH(order_date) AS month,
    SUM(sales) AS revenue
FROM ecom_sales
GROUP BY year, month;

SELECT 
    COUNT(*) AS total_rows,
    SUM(CASE WHEN product_name IS NULL THEN 1 ELSE 0 END) AS null_products,
    SUM(CASE WHEN sales <= 0 THEN 1 ELSE 0 END) AS invalid_sales
FROM ecom_sales;
